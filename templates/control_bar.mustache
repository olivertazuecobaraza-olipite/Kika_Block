{{!
    @template block_kika_chat/control_bar

    This template renders the control_bar.

    Example context (json):
    {
        "logging_enabled": boolean, true if logging is enabled in the plugin settings
        "is_edit_mode": boolean; true if edit mode is active
        "pix_popout": relative url of the popout pix to the root of moodle
        "pix_arrow_right": relative url of the arrow right pix to the root of moodle
        "pix_refresh": relative url of the refresh pix to the root of moodle
    }
}}

{{^is_edit_mode}}
    {{#logging_enabled}}
        <div title='{{#str}}loggingenabled, block_kika_chat{{/str}}' class='recording'></div>
    {{/logging_enabled}}
{{/is_edit_mode}}

<div id="control_bar" class="openai-control-bar">
    <div class="openai-input-card">
        <!-- Plus icon on the far left -->
        <button class="openai-add-btn" type="button" title="Acciones">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="input-btn-icon">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
        </button>

        <!-- Message textarea -->
        <textarea rows="1" id="openai_input" placeholder="{{#str}}askaquestion, block_kika_chat{{/str}}" name="message"></textarea>

        <!-- Submit button on the far right -->
        <button class="openai-submit-btn" id="go" title="{{#str}}submit, block_kika_chat{{/str}}" type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="send-icon">
                <line x1="22" y1="2" x2="11" y2="13"></line>
                <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
            </svg>
        </button>
    </div>
</div>
